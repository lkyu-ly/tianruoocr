  <PropertyGroup>
    <!-- <PostBuildEvent>if /I "$(PlatformName)" == "x86" (
    echo Deleting x64-only WeChatOcr components for x86 build...

    rem 删除 WeChatOcr 的托管DLL
    if exist "$(TargetDir)WeChatOcr.dll" (
        del /F /Q "$(TargetDir)WeChatOcr.dll"
    )

    rem 删除 WeChatOcr 依赖的 wco_data 文件夹
    if exist "$(TargetDir)wco_data" (
        rmdir /S /Q "$(TargetDir)wco_data"
    )
)</PostBuildEvent> -->
    <PostBuildEvent>
    if /I "$(PlatformName)" == "x86" (
        echo Deleting x64-only WeChatOcr components for x86 build...
        if exist "$(TargetDir)wco_data" (
            rmdir /S /Q "$(TargetDir)wco_data"
        )
    )
    IF EXIST "$(TargetDir)dll" ( RD /S /Q "$(TargetDir)dll" )
    IF EXIST "$(TargetDir)PaddleOCR_data" ( RD /S /Q "$(TargetDir)PaddleOCR_data" )
    IF EXIST "$(TargetDir)inference" ( RD /S /Q "$(TargetDir)inference" )

    if not exist "$(TargetDir)Data\modes" mkdir "$(TargetDir)Data\modes"
    copy /Y "$(ProjectDir)docs\modeconfigs\OCRModes.json" "$(TargetDir)Data\modes\"
    copy /Y "$(ProjectDir)docs\modeconfigs\TranslateModes.json" "$(TargetDir)Data\modes\"

    if not exist "$(TargetDir)lib" mkdir "$(TargetDir)lib"
    if exist "$(TargetDir)*.dll" move /Y "$(TargetDir)*.dll" "$(TargetDir)lib\"
    if exist "$(TargetDir)*.pdb" move /Y "$(TargetDir)*.pdb" "$(TargetDir)lib\"
    if exist "$(TargetDir)*.xml" move /Y "$(TargetDir)*.xml" "$(TargetDir)lib\"
    if exist "$(TargetDir)lib\天若OCR文字识别.pdb" move /Y "$(TargetDir)lib\天若OCR文字识别.pdb" "$(TargetDir)"

    if /I "$(PlatformName)" == "x64" (
        if exist "$(TargetDir)lib\Sdcb.*.dll" move /Y "$(TargetDir)lib\Sdcb.*.dll" "$(TargetDir)"
        if exist "$(TargetDir)lib\Sdcb.*.xml" move /Y "$(TargetDir)lib\Sdcb.*.xml" "$(TargetDir)"
    )
    </PostBuildEvent>
  </PropertyGroup>
  <!-- ShareX 构建配置说明：
       通过 sln 构建时，MSBuild 的 AssignProjectConfiguration 会向 SDK-style ProjectReference
       添加 GlobalPropertiesToRemove=Configuration;Platform，导致 SetConfiguration/AdditionalProperties
       设置的值被移除。因此 ShareX 子项目的 Configuration 由其 Directory.Build.props 兜底设定
       （空值时默认 Release），而非依赖此处的 ProjectReference 元数据传递。 -->
  <ItemGroup>
    <ProjectReference Include="external\ShareX\ShareX.HelpersLib\ShareX.HelpersLib.csproj">
      <Name>ShareX.HelpersLib</Name>
    </ProjectReference>
    <ProjectReference Include="external\ShareX\ShareX.ImageEffectsLib\ShareX.ImageEffectsLib.csproj">
      <Name>ShareX.ImageEffectsLib</Name>
    </ProjectReference>
    <ProjectReference Include="external\ShareX\ShareX.MediaLib\ShareX.MediaLib.csproj">
      <Name>ShareX.MediaLib</Name>
    </ProjectReference>
    <ProjectReference Include="external\ShareX\ShareX.ScreenCaptureLib\ShareX.ScreenCaptureLib.csproj">
      <Name>ShareX.ScreenCaptureLib</Name>
    </ProjectReference>
  </ItemGroup>
  <!-- ShareX 简体中文 satellite resource 保留：
       高级截图使用 ShareX.ScreenCaptureLib 的标注 UI，需要 zh-CN 资源显示中文。
       主程序集在 PostBuild 中移动到 lib，因此 zh-CN satellite assemblies 也移动到 lib\zh-CN。
       其他文化资源继续删除，避免输出体积回退。 -->
  <Target Name="KeepOnlyShareXZhCnSatelliteResourcesInOutput" AfterTargets="PostBuildEvent">
    <ItemGroup>
      <ShareXZhCnSatelliteResourceFiles Include="$(TargetDir)zh-CN\ShareX.*.resources.dll" />
      <ShareXSatelliteResourceFilesToDelete Include="$(TargetDir)**\ShareX.*.resources.dll"
                                             Exclude="$(TargetDir)zh-CN\ShareX.*.resources.dll;$(TargetDir)lib\zh-CN\ShareX.*.resources.dll" />
    </ItemGroup>
    <MakeDir Directories="$(TargetDir)lib\zh-CN" Condition="'@(ShareXZhCnSatelliteResourceFiles)' != ''" />
    <Copy SourceFiles="@(ShareXZhCnSatelliteResourceFiles)"
          DestinationFolder="$(TargetDir)lib\zh-CN\"
          SkipUnchangedFiles="true" />
    <Delete Files="@(ShareXZhCnSatelliteResourceFiles)" />
    <Delete Files="@(ShareXSatelliteResourceFilesToDelete)" />
    <Exec Command="for /d %%d in (&quot;$(TargetDir)*&quot;) do (dir /b &quot;%%d&quot; | findstr . &gt;nul || rd &quot;%%d&quot;)" IgnoreExitCode="true" />
  </Target>
